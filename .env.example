# MeetYou environment variable template
# Copy this file to .env and fill in your real secrets.

# Main chat LLM API key
MEETYOU_API_KEY=your_api_key_here

# Heartbeat LLM API key
MEETYOU_HEARTBEAT_API_KEY=your_heartbeat_api_key_here

# Embedding API key
MEETYOU_EMBEDDING_API_KEY=your_embedding_api_key_here

# Gateway access token
MEETYOU_GATEWAY_ACCESS_TOKEN=replace_with_a_long_random_token

# Endpoint WebSocket access token (/endpoint/ws primary path)
MEETYOU_CLIENT_ACCESS_TOKEN=replace_with_a_long_random_token

# Optional desktop endpoint provider connection overrides
MEETYOU_CORE_BASE_URL=http://127.0.0.1:8000
MEETYOU_DESKTOP_PROVIDER_ID=desktop-main-provider
MEETYOU_DESKTOP_PROVIDER_DISPLAY_NAME=Desktop Main Endpoint Provider
MEETYOU_DESKTOP_PROVIDER_WORKSPACES=personal,desktop-main,study

# Optional edge endpoint provider specific overrides
MEETYOU_EDGE_BASE_URL=http://127.0.0.1:8000
MEETYOU_EDGE_CLIENT_ACCESS_TOKEN=
MEETYOU_EDGE_PROVIDER_ID=edge-provider
MEETYOU_EDGE_PROVIDER_DISPLAY_NAME=Edge Endpoint Provider
MEETYOU_EDGE_PROVIDER_TYPE=edge

# PostgreSQL database URL
MEETYOU_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/meetyou

# Tavily web search API key
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# Notion MCP integration token
NOTION_TOKEN=ntn_your_notion_token_here

# Feishu bot config
MEETYOU_FEISHU_APP_ID=your_feishu_app_id_here
MEETYOU_FEISHU_APP_SECRET=your_feishu_app_secret_here

# Optional MeetWeChat Client config
MEETYOU_MEETWECHAT_ENABLE=false
MEETYOU_MEETWECHAT_BASE_URL=http://127.0.0.1:38961
MEETYOU_MEETWECHAT_POLL_INTERVAL_SECONDS=2
MEETYOU_MEETWECHAT_ERROR_BACKOFF_SECONDS=2
MEETYOU_MEETWECHAT_MAX_TEXT_CHARS=1800
MEETYOU_MEETWECHAT_STATE_FILE=user/meetwechat_client_state.json
MEETYOU_MEETWECHAT_INBOUND_WORKERS=4
MEETYOU_MEETWECHAT_INBOUND_QUEUE_SIZE=500
MEETYOU_MEETWECHAT_OUTBOUND_WORKERS=2
MEETYOU_MEETWECHAT_OUTBOUND_QUEUE_SIZE=500
MEETYOU_MEETWECHAT_OUTBOUND_MIN_INTERVAL_MS=250
MEETYOU_MEETWECHAT_SEND_TIMEOUT_MS=10000
MEETYOU_MEETWECHAT_STATE_FLUSH_INTERVAL_MS=500
MEETYOU_MEETWECHAT_GATEWAY_ENDPOINT_IDLE_TTL_SECONDS=600

# Optional endpoint provider runtime concurrency
MEETYOU_ENDPOINT_MAX_PARALLEL_CALLS=2
