# MeetYou environment variable template
# Copy this file to .env and fill in your real secrets.

# Main chat LLM API key
MEETYOU_API_KEY=your_api_key_here

# Heartbeat LLM API key
MEETYOU_HEARTBEAT_API_KEY=your_heartbeat_api_key_here

# Embedding API key
MEETYOU_EMBEDDING_API_KEY=your_embedding_api_key_here

# Gateway access token
MEETYOU_GATEWAY_ACCESS_TOKEN=replace_with_a_long_random_token

# Shared agent access token (desktop-agent / edge-agent both support falling back to this value)
MEETYOU_AGENT_ACCESS_TOKEN=replace_with_a_long_random_token

# Optional desktop-agent connection overrides
MEETYOU_AGENT_BASE_URL=http://127.0.0.1:8000
MEETYOU_AGENT_OWNER_CLIENT_ID=desktop-app
MEETYOU_AGENT_OWNER_CLIENT_TYPE=electron
MEETYOU_AGENT_OWNER_CLIENT_DISPLAY_NAME=Desktop App

# Optional edge-agent specific overrides
MEETYOU_EDGE_BASE_URL=http://127.0.0.1:8000
MEETYOU_EDGE_ACCESS_TOKEN=replace_with_a_long_random_token
MEETYOU_EDGE_AGENT_ID=edge-agent
MEETYOU_EDGE_DISPLAY_NAME=Edge Agent
MEETYOU_EDGE_AGENT_TYPE=edge

# PostgreSQL database URL
MEETYOU_DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/meetyou

# Tavily web search API key
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# Notion MCP integration token
NOTION_TOKEN=ntn_your_notion_token_here

# Feishu bot config
MEETYOU_FEISHU_APP_ID=your_feishu_app_id_here
MEETYOU_FEISHU_APP_SECRET=your_feishu_app_secret_here
