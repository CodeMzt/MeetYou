{
  "mode": "blacklist",
  "whitelist": [
    "dir",
    "type",
    "echo",
    "ping",
    "ipconfig",
    "systeminfo",
    "hostname",
    "whoami",
    "date",
    "time",
    "tree",
    "where",
    "python --version",
    "node --version",
    "git status",
    "git log",
    "git diff",
    "git branch"
  ],
  "blacklist_patterns": [
    "rm -rf",
    "del /s",
    "del /q",
    "erase",
    "rd /s",
    "rmdir /s",
    "Remove-Item",
    "format ",
    "diskpart",
    "shutdown",
    "restart",
    "reboot",
    "Stop-Computer",
    "Restart-Computer",
    "reg delete",
    "reg add",
    "reg import",
    "regedit",
    "powershell -enc",
    "powershell -e ",
    "EncodedCommand",
    "Invoke-Expression",
    "iex",
    "curl.*\\|.*(sh|bash|powershell|pwsh|cmd)",
    "wget.*\\|.*(sh|bash|powershell|pwsh|cmd)",
    "Invoke-WebRequest.*\\|",
    "mkfs",
    "dd if=",
    "chmod 777",
    "chown",
    "takeown",
    "icacls",
    "net user",
    "net localgroup",
    "sc delete",
    "taskkill /f",
    "Stop-Process",
    "git reset --hard",
    "git clean -fdx",
    "kubectl delete",
    "Set-ExecutionPolicy"
  ]
}
