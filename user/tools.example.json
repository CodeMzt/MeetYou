        "parameters": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string"
            },
            "structure": {
              "type": "string",
              "enum": ["outline"]
            },
            "title": {
              "type": "string"
            },
            "focus": {
              "type": "string"
            }
          },
          "required": ["text"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "extract_action_items",
        "description": "Extract likely action items, due hints, and owner hints from free-form notes.",
        "parameters": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string"
            },
            "focus": {
              "type": "string"
            },
            "max_items": {
              "type": "integer"
            }
          },
          "required": ["text"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "remember_knowledge",
