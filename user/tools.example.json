          "required": ["path"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "read_local_documents",
        "description": "Read local files and extract normalized content chunks.",
        "parameters": {
          "type": "object",
          "properties": {
            "paths": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              ]
            },
            "goal": {
              "type": "string"
            }
          },
          "required": ["paths"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "write_local_document",
