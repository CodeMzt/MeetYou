{
  "common_tools": [
    {
      "type": "function",
      "function": {
        "name": "exec_sys_cmd",
        "description": "Execute a local shell command. Dangerous commands may be blocked by policy.",
        "parameters": {
          "type": "object",
          "properties": {
            "cmd": {
              "type": "string",
              "description": "The command to execute."
            }
          },
          "required": ["cmd"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "ask_human",
        "description": "Ask the human a follow-up question and continue the same tool-calling round after the reply arrives.",
        "parameters": {
          "type": "object",
          "properties": {
            "question": {
              "type": "string",
              "description": "The question to ask."
            },
            "options": {
              "type": "array",
              "description": "Optional ordered options for a single-choice reply.",
              "items": {
                "type": "string"
              }
            },
            "placeholder": {
              "type": "string",
              "description": "Optional short UI placeholder."
            },
            "timeout_seconds": {
              "type": "integer",
              "description": "Optional timeout in seconds."
            }
          },
          "required": ["question"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "get_current_system_time",
        "description": "Get the real current system time from the host machine.",
        "parameters": {
          "type": "object",
          "properties": {},
          "required": []
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "get_sys_vitals",
        "description": "Get host machine vitals such as CPU and memory usage.",
        "parameters": {
          "type": "object",
          "properties": {},
          "required": []
        }
      }
    }
  ],
  "chain_tools": [
    {
      "type": "function",
      "function": {
        "name": "research_topic",
        "description": "Research a topic using the configured search and source-reading chain.",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "The topic or question to research."
            },
            "goal": {
              "type": "string",
              "description": "Optional focus for the research."
            }
          },
          "required": ["query"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "inspect_page",
        "description": "Inspect a direct webpage or PDF URL.",
        "parameters": {
          "type": "object",
          "properties": {
            "url": {
              "type": "string",
              "description": "The URL to inspect."
            },
            "goal": {
              "type": "string",
              "description": "Optional extraction focus."
            }
          },
          "required": ["url"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "search_knowledge",
        "description": "Search private knowledge such as memory or connected knowledge sources.",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "The lookup query."
            },
            "scope": {
              "type": "string",
              "enum": ["auto", "memory", "notion"],
              "description": "Optional scope."
            }
          },
          "required": ["query"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "manage_tasks",
        "description": "Create, list, inspect, update, complete, delete, or restore user TODO items.",
        "parameters": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["create", "list", "detail", "update", "complete", "delete", "restore"]
            },
            "task_key": {
              "type": "string"
            },
            "task_keys": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "summary": {
              "type": "string"
            },
            "completion_summary": {
              "type": "string"
            },
            "project": {
              "type": "string"
            },
            "task_status": {
              "type": "string",
              "enum": ["open", "blocked", "done"]
            },
            "deadline": {
              "type": "string"
            },
            "query": {
              "type": "string"
            },
            "limit": {
              "type": "integer"
            }
          },
          "required": ["action"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "manage_scheduled_tasks",
        "description": "Create, list, inspect, update, complete, cancel, disable, delete, or restore assistant-owned scheduled tasks.",
        "parameters": {
          "type": "object",
          "properties": {
            "action": {
              "type": "string",
              "enum": ["create", "list", "detail", "update", "complete", "delete", "cancel", "disable", "restore"]
            },
            "task_key": {
              "type": "string"
            },
            "task_keys": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "summary": {
              "type": "string"
            },
            "completion_summary": {
              "type": "string"
            },
            "project": {
              "type": "string"
            },
            "task_status": {
              "type": "string",
              "enum": ["open", "blocked", "done"]
            },
            "deadline": {
              "type": "string"
            },
            "query": {
              "type": "string"
            },
            "limit": {
              "type": "integer"
            },
            "schedule_kind": {
              "type": "string",
              "enum": ["once", "recurring"]
            },
            "due_at": {
              "type": "string"
            },
            "timezone": {
              "type": "string"
            },
            "recurrence": {
              "oneOf": [
                {
                  "type": "string"
                },
                {
                  "type": "object",
                  "properties": {
                    "freq": {
                      "type": "string",
                      "enum": ["daily", "weekly"]
                    },
                    "weekday": {
                      "oneOf": [
                        {
                          "type": "integer"
                        },
                        {
                          "type": "string"
                        }
                      ]
                    },
                    "hour": {
                      "type": "integer"
                    },
                    "minute": {
                      "type": "integer"
                    }
                  }
                }
              ]
            },
            "auto_run": {
              "type": "boolean"
            },
            "job_prompt": {
              "type": "string"
            },
            "notify_policy": {
              "type": "string",
              "enum": ["on_due", "on_completion", "silent"]
            }
          },
          "required": ["action"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "list_skills",
        "description": "List the currently available open skills.",
        "parameters": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string"
            },
            "skill_type": {
              "type": "string",
              "enum": ["all", "mode", "reusable"]
            }
          },
          "required": []
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "load_skill",
        "description": "Load a skill by identifier and optionally inject it into the current route context.",
        "parameters": {
          "type": "object",
          "properties": {
            "skill_id": {
              "type": "string"
            },
            "inject_context": {
              "type": "boolean"
            }
          },
          "required": ["skill_id"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "create_skill",
        "description": "Create a new reusable skill in the open skill registry.",
        "parameters": {
          "type": "object",
          "properties": {
            "skill_id": {
              "type": "string"
            },
            "title": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "content": {
              "type": "string"
            },
            "recommended_tools": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "applicable_modes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "scenarios": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "inject_context": {
              "type": "boolean"
            }
          },
          "required": ["title", "summary", "content"]
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "summarize_text",
