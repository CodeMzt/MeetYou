{
  "name": "meetyou-ui",
  "version": "1.0.0",
  "description": "MeetYou Desktop Floating Widget",
  "main": "dist-electron/main.js",
  "build": {
    "appId": "com.meetyou.app",
    "productName": "MeetYou",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/desktop-backend",
        "to": "desktop-backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/runtime-template",
        "to": "runtime-template",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "icon": "public/icon.png"
    },
    "win": {
      "icon": "public/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "public/icon.png"
    }
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "tsc && vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "@types/d3-force": "^3.0.10",
    "@types/react-syntax-highlighter": "^15.5.13",
    "d3-force": "^3.0.0",
    "framer-motion": "^11.0.5",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.20",
    "@types/react": "^18.2.58",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^29.0.1",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-plugin-electron": "^0.28.2",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.2"
  }
}
