                    "type": "object",
                    "properties": {
                        "cmd": {
                            "type": "string",
                            "description": "需要执行的具体终端命令，例如 'dir' (Windows上的命令行指令)"
                        }
                    },
                    "required": [
                        "cmd"
                    ]
                }
            }
        },
        {
