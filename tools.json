                "parameters": {
                    "type": "object",
                    "properties": {},
                    "required": []
                }
            }
        }
    ],
    "memory_tools": [
        {
            "type": "function",
            "function": {
                "name": "save_memory",
                "description": "【核心记忆守则】将一条信息编码为高维向量并存入记忆图谱。适用场景：记录约定、偏好或重要设定。⚠ 警告（最高防错杠杆）：由于记忆片段是独立存储无上下文的，memory_text 中【绝对禁止】出现“今天、明天、现在、下周”等相对时间标记词。如果涉及时间事件，必须要强制转换并记录为明确的【绝对真实系统日期】（格式如“2026年3月20日”）。如果不清楚当前环境真实时间，必须先调用 get_current_system_time 获取时间锚点再进行存储。",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "memory_text": {
                            "type": "string",
                            "description": "需要记忆的具体内容。应包含完整的上下文信息，确保未来召回时无需额外解释即可理解。例如：'用户的猫叫小橘，是一只3岁的橘猫'，而非仅'小橘'。"
                        },
                        "text_emotion_intensity": {
                            "type": "number",
                            "description": "这条记忆的情绪强度（0.0~1.0）。影响初始记忆权重和每次被回忆时的强化幅度。高情绪强度的记忆更难遗忘。参考：日常琐事约0.2，普通事件约0.5，重要约定/决策约0.7，强烈情感事件（如悲伤、惊喜、愤怒）约0.9~1.0。默认值为0.5。"
                        }
                    },
                    "required": [
                        "memory_text",
                        "text_emotion_intensity"
                    ]
                }
            }
        },
        {
            "type": "function",
            "function": {
                "name": "recall_memory",
                "description": "通过语义相似度在记忆图谱中检索相关记忆。系统会将查询文本编码为向量，在所有记忆节点中找到最相关的锚点，然后沿突触网络向外扩散搜索，返回关联的记忆片段及其记忆强度。适用场景：用户提问涉及之前的约定/设定/偏好、对话需要历史背景信息补充、你不确定之前是否讨论过某个话题。注意：此操作只读取记忆，不会写入新记忆。",
                "parameters": {
                    "type": "object",
                    "properties": {
                        "query_text": {
                            "type": "string",
                            "description": "用于语义检索的查询语句，应尽量精炼并聚焦于想要回忆的主题。例如：'用户的宠物信息'、'项目的技术栈选择'。"
                        }
                    },
                    "required": [
                        "query_text"
                    ]
                }
            }
        }
    ],
    "context_tools": [
        {
            "type": "function",
