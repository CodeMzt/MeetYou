# MeetYou external Endpoint Provider environment example

MEETYOU_CORE_BASE_URL=http://127.0.0.1:8000
MEETYOU_GATEWAY_ACCESS_TOKEN=replace_with_a_long_random_token
MEETYOU_CLIENT_ACCESS_TOKEN=replace_with_a_long_random_token

# Feishu Provider
MEETYOU_FEISHU_ENABLE=false
MEETYOU_FEISHU_APP_ID=
MEETYOU_FEISHU_APP_SECRET=

# WeChatBot / MeetWeChat Provider
MEETYOU_MEETWECHAT_ENABLE=false
MEETYOU_MEETWECHAT_BASE_URL=http://127.0.0.1:38961
MEETYOU_MEETWECHAT_STATE_FILE=user/meetwechat_client_state.json
