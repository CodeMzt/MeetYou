# MeetYou Research Adapter environment example

MEETYOU_RESEARCH_ADAPTER_HOST=127.0.0.1
MEETYOU_RESEARCH_ADAPTER_PORT=8011
MEETYOU_RESEARCH_ADAPTER_TOKEN=replace_with_a_long_random_token
MEETYOU_RESEARCH_PROVIDER=gpt_researcher
MEETYOU_RESEARCH_ADAPTER_FAKE=false

# GPT Researcher provider configuration.
# The adapter unit also reads /etc/meetyou/meetyou-core.env before this file.
# Put provider keys here only when they must differ from Core; do not leave blank
# OPENAI_API_KEY/TAVILY_API_KEY assignments because systemd would override Core
# values with empty strings.
# OPENAI_API_KEY=...
# TAVILY_API_KEY=...
