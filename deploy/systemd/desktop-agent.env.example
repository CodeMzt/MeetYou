# MeetYou Desktop Agent environment example

MEETYOU_AGENT_BASE_URL=https://your-domain.example
MEETYOU_AGENT_WS_ACCESS_TOKEN=replace_with_agent_token
MEETYOU_AGENT_ID=desktop-main-agent
MEETYOU_AGENT_DISPLAY_NAME=Desktop Main Agent
MEETYOU_AGENT_OWNER_CLIENT_ID=desktop-app
MEETYOU_AGENT_OWNER_CLIENT_TYPE=electron
MEETYOU_AGENT_OWNER_CLIENT_DISPLAY_NAME=Desktop App
MEETYOU_AGENT_WORKSPACES=personal,desktop-main,study
MEETYOU_AGENT_HEARTBEAT_SECONDS=20
MEETYOU_AGENT_RECONNECT_SECONDS=3
MEETYOU_CREDENTIAL_SECRET=
