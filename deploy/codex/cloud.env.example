# Reference values for Codex cloud environment settings.
# Do not commit real secrets here.

# Installation toggles consumed by scripts/codex/cloud-setup.sh
MEETYOU_CODEX_INSTALL_FRONTEND=1
MEETYOU_CODEX_INSTALL_DESKTOP_AGENT=1
MEETYOU_CODEX_INSTALL_EDGE_AGENT=0
MEETYOU_CODEX_VERIFY_FRONTEND=1
MEETYOU_CODEX_VERIFY_PROFILE=cloud-dev

# Runtime values used only when you need live Core or protected surfaces.
# If these stay empty, the cloud environment is still suitable for code edits,
# most unit tests, and frontend typecheck/vitest.
MEETYOU_DATABASE_URL=
MEETYOU_GATEWAY_ACCESS_TOKEN=
MEETYOU_API_KEY=
MEETYOU_HEARTBEAT_API_KEY=
MEETYOU_EMBEDDING_API_KEY=
MEETYOU_AGENT_WS_ACCESS_TOKEN=
MEETYOU_AGENT_ACCESS_TOKEN=
MEETYOU_CREDENTIAL_SECRET=
