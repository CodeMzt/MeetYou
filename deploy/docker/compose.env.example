# Docker-local overrides for deploy/docker/compose.core-postgres.yml.
# Copy to deploy/docker/compose.env and replace every placeholder before production use.

TZ=Asia/Shanghai

POSTGRES_DB=meetyou
POSTGRES_USER=meetyou
POSTGRES_PASSWORD=replace_with_a_long_random_password
POSTGRES_HOST_PORT=55432
MEETYOU_DATABASE_URL=postgresql+psycopg://meetyou:replace_with_a_long_random_password@postgres:5432/meetyou

MEETYOU_GATEWAY_ACCESS_TOKEN=replace_with_a_long_random_token
MEETYOU_GATEWAY_HOST_PORT=8000

# Optional Core-host command execution overrides. The tool is whitelist-bound
# and runs on the Core container/host, not on a Desktop Endpoint Provider.
MEETYOU_CORE_SHELL_EXEC_ENABLED=true
MEETYOU_CORE_CMD_POLICY_PATH=user/core_cmd_policy.json
MEETYOU_CORE_COMMAND_TIMEOUT_SECONDS=120
MEETYOU_CORE_COMMAND_OUTPUT_MAX_CHARS=20000

# Optional MeetWeChat Client runtime overrides. Keep disabled until low-frequency
# text-loop acceptance is performed for this deployment.
MEETYOU_MEETWECHAT_ENABLE=false
MEETYOU_MEETWECHAT_BASE_URL=http://127.0.0.1:38961
MEETYOU_MEETWECHAT_POLL_INTERVAL_SECONDS=2
MEETYOU_MEETWECHAT_ERROR_BACKOFF_SECONDS=2
MEETYOU_MEETWECHAT_MAX_TEXT_CHARS=1800
MEETYOU_MEETWECHAT_STATE_FILE=user/meetwechat_client_state.json
MEETYOU_MEETWECHAT_INBOUND_WORKERS=4
MEETYOU_MEETWECHAT_INBOUND_QUEUE_SIZE=500
MEETYOU_MEETWECHAT_OUTBOUND_WORKERS=2
MEETYOU_MEETWECHAT_OUTBOUND_QUEUE_SIZE=500
MEETYOU_MEETWECHAT_OUTBOUND_MIN_INTERVAL_MS=250
MEETYOU_MEETWECHAT_SEND_TIMEOUT_MS=10000
MEETYOU_MEETWECHAT_STATE_FLUSH_INTERVAL_MS=500
MEETYOU_MEETWECHAT_GATEWAY_ENDPOINT_IDLE_TTL_SECONDS=600
